ENVIRONMENT=development
# Comma-separated origins (a JSON array also works, but plain comma-separated
# is far less likely to get mangled when typed into a dashboard's env field).
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# SQLite by default. In Docker/production, point this at a persistent
# volume path, e.g. sqlite:////app/data/chatbot.db
DATABASE_URL=sqlite:///./chatbot.db

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
